lgraph = layerGraph();

% Input layer
tempNet = imageInputLayer([227 227 3],"Name","input");
lgraph = addLayers(lgraph,tempNet);

% Parallel convolution layers
tempNet = [
    convolution2dLayer(3,32,"Padding","same","Name","conv")
    ];
lgraph = addLayers(lgraph,tempNet);

tempNet = [
    convolution2dLayer(3,32,"Padding","same","Name","conv1")
    ];
lgraph = addLayers(lgraph,tempNet);

% Multiplication (x1 * x2)
tempNet = multiplicationLayer(2,"Name","mult");
lgraph = addLayers(lgraph,tempNet);

% Channel-wise sum (correlation approximation)
tempNet = functionLayer(@(X) sum(X,3),"Name","channel_sum","Formattable",true);
lgraph = addLayers(lgraph,tempNet);

% Repeat channels (expand back to 32)
tempNet = functionLayer(@(X) repmat(X,1,1,32),"Name","repeat");
lgraph = addLayers(lgraph,tempNet);

% Pooling layers
tempNet = averagePooling2dLayer(3,"Padding","same","Stride",1,"Name","avgpool");
lgraph = addLayers(lgraph,tempNet);

tempNet = maxPooling2dLayer(3,"Padding","same","Stride",1,"Name","maxpool");
lgraph = addLayers(lgraph,tempNet);

% Subtraction (max - avg)
tempNet = subtractionLayer(2,"Name","sub");
lgraph = addLayers(lgraph,tempNet);

% Global Average Pooling
tempNet = globalAveragePooling2dLayer("Name","gap");
lgraph = addLayers(lgraph,tempNet);

% Resize (interpolation)
tempNet = functionLayer(@(X) dlresize(X,[227 227]),"Name","upsample","Formattable",true);
lgraph = addLayers(lgraph,tempNet);

% Multiplication (second)
tempNet = multiplicationLayer(2,"Name","mult2");
lgraph = addLayers(lgraph,tempNet);

% Final addition
tempNet = additionLayer(2,"Name","add");
lgraph = addLayers(lgraph,tempNet);

%% Connections

lgraph = connectLayers(lgraph,"input","conv");
lgraph = connectLayers(lgraph,"input","conv1");

lgraph = connectLayers(lgraph,"conv","mult/in1");
lgraph = connectLayers(lgraph,"conv1","mult/in2");

lgraph = connectLayers(lgraph,"mult","channel_sum");
lgraph = connectLayers(lgraph,"channel_sum","repeat");

lgraph = connectLayers(lgraph,"repeat","avgpool");
lgraph = connectLayers(lgraph,"repeat","maxpool");

lgraph = connectLayers(lgraph,"maxpool","sub/in1");
lgraph = connectLayers(lgraph,"avgpool","sub/in2");

lgraph = connectLayers(lgraph,"maxpool","gap");
lgraph = connectLayers(lgraph,"gap","upsample");

lgraph = connectLayers(lgraph,"sub","mult2/in1");
lgraph = connectLayers(lgraph,"upsample","mult2/in2");

lgraph = connectLayers(lgraph,"sub","add/in1");
lgraph = connectLayers(lgraph,"mult2","add/in2");

% Initialize network
net = dlnetwork(lgraph);
