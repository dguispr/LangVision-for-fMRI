import torch
import torch.nn as nn
import torch.nn.functional as F

class CustomNet(nn.Module):
    def __init__(self):
        super(CustomNet, self).__init__()
        
        # Initial convolutions
        self.conv = nn.Conv2d(3, 32, kernel_size=3, padding=1)
        self.conv1 = nn.Conv2d(3, 32, kernel_size=3, padding=1)
        
        # Pooling layers
        self.maxpool = nn.MaxPool2d(kernel_size=3, stride=1, padding=1)
        self.maxpool1 = nn.MaxPool2d(kernel_size=3, stride=1, padding=1)
        
        # Second convolution branches
        self.conv2 = nn.Conv2d(32, 32, kernel_size=3, padding=1)
        self.conv3 = nn.Conv2d(32, 32, kernel_size=3, padding=1)

    def forward(self, x):
        # Parallel conv layers
        x1 = self.conv(x)
        x2 = self.conv1(x)
        
        # channel-wise correlation
        corr = torch.sum(x1 * x2, dim=1, keepdim=True)
        corr = corr.repeat(1, x1.shape[1], 1, 1)
        
        # Branch 1: pooling path
        pool1 = self.maxpool(corr)
        pool2 = self.maxpool1(pool1)
        
        # Branch 2: convolution path
        conv_path = self.conv2(corr)
        conv_path = self.conv3(conv_path)
        
        # Subtraction
        out = pool2 - conv_path
        
        return out
