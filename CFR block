lgraph = layerGraph();

%% Input
tempNet = imageInputLayer([227 227 3],"Name","input");
lgraph = addLayers(lgraph,tempNet);

%% Parallel Convolutions
tempNet = convolution2dLayer(3,32,"Padding","same","Name","conv");
lgraph = addLayers(lgraph,tempNet);

tempNet = convolution2dLayer(3,32,"Padding","same","Name","conv1");
lgraph = addLayers(lgraph,tempNet);

%% Multiplication (x1 * x2)
tempNet = multiplicationLayer(2,"Name","mult");
lgraph = addLayers(lgraph,tempNet);

%% Channel-wise sum (correlation)
tempNet = functionLayer(@(X) sum(X,3),"Name","channel_sum","Formattable",true);
lgraph = addLayers(lgraph,tempNet);

%% Repeat channels to 32
tempNet = functionLayer(@(X) repmat(X,1,1,32),"Name","repeat","Formattable",true);
lgraph = addLayers(lgraph,tempNet);

%% Pooling branch
tempNet = maxPooling2dLayer(3,"Stride",1,"Padding","same","Name","maxpool");
lgraph = addLayers(lgraph,tempNet);

tempNet = maxPooling2dLayer(3,"Stride",1,"Padding","same","Name","maxpool1");
lgraph = addLayers(lgraph,tempNet);

%% Convolution branch
tempNet = convolution2dLayer(3,32,"Padding","same","Name","conv2");
lgraph = addLayers(lgraph,tempNet);

tempNet = convolution2dLayer(3,32,"Padding","same","Name","conv3");
lgraph = addLayers(lgraph,tempNet);

%% Subtraction layer
tempNet = subtractionLayer(2,"Name","sub");
lgraph = addLayers(lgraph,tempNet);

%% Connections

lgraph = connectLayers(lgraph,"input","conv");
lgraph = connectLayers(lgraph,"input","conv1");

lgraph = connectLayers(lgraph,"conv","mult/in1");
lgraph = connectLayers(lgraph,"conv1","mult/in2");

lgraph = connectLayers(lgraph,"mult","channel_sum");
lgraph = connectLayers(lgraph,"channel_sum","repeat");

% Pooling branch
lgraph = connectLayers(lgraph,"repeat","maxpool");
lgraph = connectLayers(lgraph,"maxpool","maxpool1");

% Conv branch
lgraph = connectLayers(lgraph,"repeat","conv2");
lgraph = connectLayers(lgraph,"conv2","conv3");

% Subtraction
lgraph = connectLayers(lgraph,"maxpool1","sub/in1");
lgraph = connectLayers(lgraph,"conv3","sub/in2");

%% Initialize network
net = dlnetwork(lgraph);
